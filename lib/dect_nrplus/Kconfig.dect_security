# Kconfig.dect_security
# Security subsystem configuration for DECT NR+ driver

config DECT_SECURITY_ENABLE
	bool "Enable DECT NR+ Security Subsystem"
	help
	  Enable the unified security subsystem for DECT NR+ MAC and CVG layers.
	  This provides encryption and authentication services.

if DECT_SECURITY_ENABLE

choice DECT_CRYPTO_BACKEND
	prompt "Cryptographic backend"
	default DECT_CRYPTO_PSA
	help
	  Select the cryptographic backend for DECT NR+ security operations.

# config DECT_CRYPTO_PSA
# 	bool "PSA Crypto API"
# 	select MBEDTLS
# 	select MBEDTLS_PSA_CRYPTO_C
# 	select PSA_CRYPTO_INIT
# 	select PSA_WANT_ALG_CTR
# 	select PSA_WANT_ALG_CMAC
# 	select PSA_WANT_ALG_ECB_NO_PADDING
# 	select PSA_WANT_KEY_TYPE_AES
# 	select PSA_WANT_AES_KEY_SIZE_128
# 	help
# 	  Use PSA Crypto API for cryptographic operations.
# 	  This is the default and recommended backend.
config DECT_CRYPTO_PSA
	bool "PSA Crypto API"
	select MBEDTLS
	select MBEDTLS_PSA_CRYPTO_C
	
	# Fixes the 'fatal error: psa/crypto.h' on the simulator
	select PSA_CRYPTO_CLIENT if !NRF_SECURITY
	
	# Hardware-specific algorithms (only exist when NRF_SECURITY=y)
	select PSA_CRYPTO_INIT if NRF_SECURITY
	select PSA_WANT_ALG_CTR if NRF_SECURITY
	select PSA_WANT_ALG_CMAC if NRF_SECURITY
	select PSA_WANT_ALG_ECB_NO_PADDING if NRF_SECURITY
	select PSA_WANT_KEY_TYPE_AES if NRF_SECURITY
	select PSA_WANT_AES_KEY_SIZE_128 if NRF_SECURITY
	help
	  Use PSA Crypto API for cryptographic operations.
	  

config DECT_CRYPTO_TINYCRYPT
	bool "TinyCrypt"
	depends on !NRF_SECURITY
	help
	  Use TinyCrypt for cryptographic operations.
	  This is a lightweight alternative for platforms without PSA support.
	  Note: Not yet implemented.

endchoice

config DECT_SECURITY_LOG_LEVEL
	int "DECT Security log level"
	default 3
	range 0 4
	help
	  Log level for the DECT security subsystem.
	  0=off, 1=error, 2=warning, 3=info, 4=debug

endif # DECT_SECURITY_ENABLE
